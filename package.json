{
  "name": "react-expenses-manager",
  "version": "1.2.0",
  "private": true,
  "dependencies": {
    "@iconify/react": "^1.1.4",
    "@reduxjs/toolkit": "^1.8.5",
    "@types/jest": "^29.1.1",
    "@types/node": "^18.8.0",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "bootstrap": "^5.2.2",
    "chart.js": "^4.4.4",
    "create-react-app": "^1.2.1",
    "dayjs": "^1.10.7",
    "lodash": "^4.17.21",
    "moment": "^2.29.1",
    "node-sass": "^7.0.3",
    "prop-types": "^15.7.2",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.4",
    "react-dom": "^18.2.0",
    "react-icons": "^4.3.1",
    "react-redux": "^8.0.4",
    "react-router-dom": "^5.3.0",
    "react-scripts": "^5.0.1",
    "react-test-renderer": "^18.2.0",
    "redux": "^4.2.0",
    "redux-devtools-extension": "^2.13.9",
    "redux-thunk": "^2.4.1",
    "typescript": "^4.8.4",
    "uuid": "^10.0.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:debug": "react-scripts --inspect=0.0.0.0 test --runInBand --no-cache",
    "eject": "react-scripts eject",
    "typecheck": "tsc --noEmit",
    "lint": "eslint -c .eslintrc.json .",
    "lint:fix": "eslint . --fix",
    "sync-server": "node server/index.js",
    "test:server": "node --test server/test/*.test.js"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "/node_modules/(?!@iconify-icons/)"
    ]
  },
  "devDependencies": {
    "@iconify-icons/codicon": "^1.1.26",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.3.3"
  }
}
